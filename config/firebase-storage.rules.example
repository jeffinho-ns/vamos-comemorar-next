rules_version = '2';
// Copie trechos para Firebase Console → Storage → Rules (ajuste ao restante do seu projeto).
// Galeria admin usa list() em cada prefixo — sem "allow list" a pasta aparece vazia.
service firebase.storage {
  match /b/{bucket}/o {
    match /cardapio/{allPaths=**} {
      allow list, read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /events/{allPaths=**} {
      allow list, read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /users/{allPaths=**} {
      allow list, read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /giro-certo/{allPaths=**} {
      allow list, read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /migrations/{allPaths=**} {
      allow list, read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /smoke-test/{allPaths=**} {
      allow list, read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
